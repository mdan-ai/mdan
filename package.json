{
  "name": "@mdanai/sdk",
  "version": "0.7.6",
  "private": false,
  "description": "TypeScript runtime SDK for MDAN interactive Markdown plus JSON surfaces.",
  "license": "MIT",
  "homepage": "https://docs.mdan.ai",
  "bugs": {
    "url": "https://github.com/mdan-ai/mdan/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mdan-ai/mdan.git"
  },
  "keywords": [
    "mdan",
    "agent-app",
    "skills-app",
    "agent-app-sdk",
    "markdown-json-runtime",
    "interactive-markdown",
    "markdown-actions"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "dist-browser",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/build-browser-bundles.mjs && bunx tsc -b tsconfig.json --force && npm run build:create-mdan",
    "build:create-mdan": "npm --prefix create-mdan run build",
    "build:docs-site": "bunx tsc -p docs-site/tsconfig.json",
    "build:browser": "node scripts/build-browser-bundles.mjs",
    "build:browser:watch": "node scripts/build-browser-bundles.mjs --watch",
    "build:watch": "bunx tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:auth-guestbook": "node scripts/run-example-dev.mjs examples/auth-guestbook/dev.ts",
    "dev:docs-site": "node docs-site/dev.mjs",
    "dev:docs-starter": "node scripts/run-example-dev.mjs examples/docs-starter/dev.ts",
    "dev:starter": "node scripts/run-example-dev.mjs examples/starter/dev.ts",
    "lint": "eslint src test examples create-mdan/src create-mdan/test docs-site/src vitest.baseline.config.ts --max-warnings=0",
    "lint:names": "npm run lint",
    "prepack": "node scripts/prepare-npm-package.mjs --package . --readme README.md",
    "postpack": "node scripts/prepare-npm-package.mjs --package . --readme README.md --restore true",
    "prepublishOnly": "npm run build",
    "test": "bun run test:baseline",
    "test:baseline": "bunx vitest run --config vitest.baseline.config.ts",
    "test:coverage": "bunx vitest run --config vitest.baseline.config.ts --coverage",
    "test:markdown-runtime": "bunx vitest run test/core/surface-adapter.test.ts test/server/runtime-json-contract-mode.test.ts test/server/auth-guestbook-markdown-example.test.ts",
    "test:smoke": "bun run test:markdown-runtime",
    "test:tssdk-migrated": "bunx vitest run test",
    "test:create-mdan": "bunx vitest run create-mdan/test"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app/index.d.ts",
      "default": "./dist/app/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./frontend": {
      "types": "./dist/frontend/index.d.ts",
      "default": "./dist/frontend/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./server/node": {
      "types": "./dist/server/node-runtime.d.ts",
      "default": "./dist/server/node-runtime.js"
    },
    "./server/bun": {
      "types": "./dist/server/bun.d.ts",
      "default": "./dist/server/bun.js"
    },
    "./surface": {
      "types": "./dist/surface/index.d.ts",
      "default": "./dist/surface/index.js"
    }
  },
  "dependencies": {
    "lit": "^3.3.1",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "happy-dom": "^20.8.9",
    "vitest": "^4.1.4"
  }
}
