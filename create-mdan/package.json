{
  "name": "create-mdan",
  "version": "0.7.0",
  "private": false,
  "description": "Scaffold a minimal MDAN agent app with npm create or bunx.",
  "license": "MIT",
  "homepage": "https://docs.mdan.ai",
  "bugs": {
    "url": "https://github.com/mdan-ai/mdan/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mdan-ai/mdan.git"
  },
  "keywords": [
    "mdan",
    "markdown-action-notation",
    "agent-app",
    "agent-starter",
    "interactive-markdown",
    "markdown-actions",
    "create",
    "scaffold",
    "starter",
    "template",
    "cli"
  ],
  "type": "module",
  "main": "./dist/scaffold.js",
  "types": "./dist/scaffold.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "template/shared",
    "template/node",
    "template/bun"
  ],
  "bin": {
    "create-mdan": "./dist/cli-bin.js"
  },
  "scripts": {
    "build": "bunx tsc -b tsconfig.json --force",
    "postbuild": "chmod +x dist/cli-bin.js",
    "test": "bunx vitest run test"
  },
  "exports": {
    ".": {
      "types": "./dist/scaffold.d.ts",
      "default": "./dist/scaffold.js"
    }
  }
}
