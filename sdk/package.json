{
  "name": "@mdanai/sdk",
  "version": "0.5.0",
  "private": false,
  "description": "TypeScript reference SDK for building MDAN agent apps with interactive Markdown pages and actions.",
  "license": "MIT",
  "homepage": "https://docs.mdan.ai",
  "bugs": {
    "url": "https://github.com/mdan-ai/mdan/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mdan-ai/mdan.git"
  },
  "keywords": [
    "mdan",
    "markdown-action-notation",
    "agent-app",
    "skills-app",
    "agent-interface",
    "agent-interaction",
    "agent-native",
    "agent-readable-markdown",
    "interactive-markdown",
    "markdown-actions",
    "markdown-apps",
    "agent",
    "multi-step-agent-workflows",
    "interactive-documents"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "node ../scripts/sync-package-license.mjs",
    "postpack": "node ../scripts/sync-package-license.mjs --cleanup"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "default": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./server/node": {
      "types": "./dist/server/node-runtime.d.ts",
      "default": "./dist/server/node-runtime.js"
    },
    "./server/bun": {
      "types": "./dist/server/bun.d.ts",
      "default": "./dist/server/bun.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "default": "./dist/web/index.js"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "default": "./dist/elements/index.js"
    }
  },
  "dependencies": {
    "lit": "^3.3.1"
  }
}
